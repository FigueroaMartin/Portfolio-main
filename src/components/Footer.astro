---
import { SITE } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-edge">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-5 py-8 font-mono text-xs text-muted sm:px-8"
  >
    <p>
      © {year} {SITE.name} <span class="text-accent">·</span> mf<span class="text-accent">·</span>
    </p>
    <p>
      Hecho con
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink underline underline-offset-4 transition-colors duration-200 hover:text-accent">Astro</a
      >
      — contenido 100% basado en repos reales.
    </p>
  </div>
</footer>
