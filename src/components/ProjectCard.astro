---
import type { Project } from '../types';

interface Props {
  project: Project;
  index: number;
}
const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article
  data-reveal
  style={`--reveal-delay: ${(index % 3) * 70}ms`}
  class:list={[
    'group relative flex flex-col rounded-lg border border-edge bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/60 hover:shadow-[0_0_0_1px_var(--accent-soft),0_12px_40px_-12px_var(--accent-soft)]',
    project.highlight && 'md:col-span-2',
  ]}
>
  <div class="flex items-baseline justify-between gap-4">
    <p class="font-mono text-xs tracking-widest text-muted">
      {num} · {project.kind} · {project.year}
    </p>
    <div class="flex items-center gap-3">
      {
        project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-10 font-mono text-xs text-accent underline-offset-4 transition-all duration-200 hover:underline"
            aria-label={`Demo en vivo de ${project.name} (se abre en una pestaña nueva)`}
          >
            demo ↗
          </a>
        )
      }
      <a
        href={project.repo}
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-10 font-mono text-xs text-muted underline-offset-4 transition-all duration-200 hover:text-accent hover:underline"
        aria-label={`Código de ${project.name} en GitHub (se abre en una pestaña nueva)`}
      >
        código ↗
      </a>
    </div>
  </div>

  <h3 class="mt-4 font-display text-2xl font-bold text-ink transition-colors duration-200 group-hover:text-accent">
    {project.name}
  </h3>

  <p class="mt-3 flex-1 text-[15px] leading-relaxed text-muted">{project.summary}</p>

  <ul class="mt-5 flex flex-wrap gap-2" aria-label={`Tecnologías de ${project.name}`}>
    {
      project.stack.map((tech) => (
        <li class="rounded border border-edge bg-accent-soft px-2 py-1 font-mono text-[11px] tracking-wide text-ink">
          {tech}
        </li>
      ))
    }
  </ul>
</article>
