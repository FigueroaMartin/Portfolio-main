---
import SectionHeader from './SectionHeader.astro';
import data from '../data/skills.json';
import type { SkillGroup } from '../types';

const groups = data.groups as SkillGroup[];
---

<section id="skills" class="border-y border-edge bg-surface/50">
  <div class="mx-auto max-w-5xl px-5 py-24 sm:px-8">
    <SectionHeader
      number="02"
      title="Skills"
      lead="Agrupadas desde los lenguajes y herramientas que realmente aparecen en mis repos — no una lista de deseos."
    />

    <div class="grid gap-x-10 gap-y-12 sm:grid-cols-2">
      {
        groups.map((group, gi) => (
          <div data-reveal style={`--reveal-delay: ${gi * 70}ms`}>
            <h3 class="flex items-center gap-3 font-display text-lg font-bold text-ink">
              <span class="h-px w-6 bg-accent" aria-hidden="true" />
              {group.title}
            </h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <li class="rounded-md border border-edge bg-bg px-3 py-1.5 font-mono text-[13px] text-muted transition-colors duration-200 hover:border-accent/50 hover:text-ink">
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
